# App (required for production — Supabase Dashboard → Settings → API)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# New format (recommended): Settings → API Keys → Publishable key
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Legacy format (still supported): Settings → API → anon public
# EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Database setup only (npm run db:setup) — NOT used by the app at runtime
# Supabase Dashboard → Settings → Database → Connection string (URI, Session pooler)
SUPABASE_DB_URL=postgresql://postgres.your-project-id:YOUR-DB-PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
