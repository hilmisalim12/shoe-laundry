<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Serve existing files and directories
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Expo static export fallbacks
  RewriteRule ^$ index.html [L]
  RewriteRule ^(.+)/$ $1.html [L]
  RewriteRule ^(.+)$ $1.html [L]
</IfModule>
